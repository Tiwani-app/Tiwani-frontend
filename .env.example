# App runtime
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_VERSION=2.1.0
EXPO_PUBLIC_DEFAULT_ORG_ID=tiwani-org-v1

# Local Firebase Emulator Suite
EXPO_PUBLIC_USE_FIREBASE_EMULATORS=false
EXPO_PUBLIC_FIREBASE_EMULATOR_HOST=127.0.0.1

# Backend callables
# Keep false until local Functions emulator or deployed Cloud Functions are ready.

# Optional local development login prefill.
# Leave blank for staging and production.
EXPO_PUBLIC_DEV_LOGIN_EMAIL=
EXPO_PUBLIC_DEV_LOGIN_PASSWORD=

# Organisation/build-specific contact points.
# Finance contacts should normally live on organisations/{orgId}. These are
# fallback values for builds where the Firestore organisation contact is absent.
EXPO_PUBLIC_FINANCE_CONTACT_EMAIL=
EXPO_PUBLIC_FINANCE_CONTACT_PHONE=
EXPO_PUBLIC_SUPPORT_URL=
EXPO_PUBLIC_PRIVACY_POLICY_URL=
EXPO_PUBLIC_TERMS_URL=
EXPO_PUBLIC_ACCOUNT_DELETION_URL=
EXPO_PUBLIC_APP_CHECK_ENABLED=false
EXPO_PUBLIC_APP_CHECK_TOKEN_AUTO_REFRESH_ENABLED=false
EXPO_PUBLIC_APP_CHECK_ANDROID_PROVIDER=playIntegrity
EXPO_PUBLIC_APP_CHECK_APPLE_PROVIDER=appAttestWithDeviceCheckFallback
EXPO_PUBLIC_APP_CHECK_ANDROID_DEBUG_TOKEN=
EXPO_PUBLIC_APP_CHECK_APPLE_DEBUG_TOKEN=
EXPO_PUBLIC_CRASHLYTICS_ENABLED=false

# Expo native identity overrides.
# Leave blank to use the defaults in app.config.js.
TIWANI_APP_NAME=
TIWANI_APP_VERSION=
TIWANI_IOS_BUNDLE_IDENTIFIER=
TIWANI_ANDROID_PACKAGE=
TIWANI_IOS_GOOGLE_SERVICES_FILE=
TIWANI_ANDROID_GOOGLE_SERVICES_FILE=
TIWANI_IOS_APS_ENVIRONMENT=

# Android release signing.
# Provide these through your shell, CI, or EAS secrets; do not commit real values.
TIWANI_UPLOAD_STORE_FILE=
TIWANI_UPLOAD_STORE_PASSWORD=
TIWANI_UPLOAD_KEY_ALIAS=
TIWANI_UPLOAD_KEY_PASSWORD=
