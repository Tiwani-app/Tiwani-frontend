{
  "name": "tiwani",
  "version": "2.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "postinstall": "node scripts/patch-react-native-gradle-plugin.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start --dev-client",
    "lint": "eslint .",
    "functions:build": "npm --prefix functions run build",
    "test:rules": "npm run test:rules:config && npm run test:rules:emulator",
    "test:rules:config": "jest src/__tests__/firebaseRulesConfig.test.ts --runInBand",
    "test:rules:emulator": "JAVA_HOME=${JAVA_HOME:-/opt/homebrew/opt/openjdk} PATH=\"${JAVA_HOME:-/opt/homebrew/opt/openjdk}/bin:$PATH\" firebase emulators:exec --only firestore \"npm run test:rules:emulator:jest\"",
    "test:rules:emulator:jest": "jest --testMatch '**/src/__tests__/firestoreRulesEmulator.spec.ts' --runInBand",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/app": "^24.1.1",
    "@react-native-firebase/app-check": "^24.1.1",
    "@react-native-firebase/auth": "^24.1.1",
    "@react-native-firebase/crashlytics": "^24.1.1",
    "@react-native-firebase/firestore": "^24.1.1",
    "@react-native-firebase/functions": "^24.1.1",
    "@react-native-firebase/messaging": "^24.1.1",
    "@react-native-firebase/storage": "^24.1.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "date-fns": "^3.6.0",
    "expo": "~55.0.26",
    "expo-build-properties": "~55.0.14",
    "expo-dev-client": "~55.0.35",
    "expo-document-picker": "~55.0.13",
    "react": "19.2.0",
    "react-hook-form": "^7.53.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/runtime": "^7.25.0",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@react-native/eslint-config": "^0.74.85",
    "@react-native/metro-config": "^0.74.85",
    "@react-native/typescript-config": "^0.74.85",
    "@types/jest": "^29.5.13",
    "@types/react": "~19.2.10",
    "eslint": "^8.57.0",
    "firebase-tools": "^15.19.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18"
  }
}
